        <methods>
            <methodStep>
                <description>
                    <para>All samples were transported to the laboratory, mosses were dried and identified at the microscope.</para>
                </description>
            </methodStep>
            <sampling>
                <studyExtent>
                    <description>
                        <para>The selection of plots was designed to cover different fens and bogs in Northwestern Italy, Piedmont, Verbano-Cusio-Ossola province at different elevation.</para>
                    </description>
                </studyExtent>
                <samplingDescription>
                    <para>Each sample consisted of approximately 0.5 kg of wet moss, collected into 1.5 L plastic zip-lock bags.</para>
                </samplingDescription>
            </sampling>
            <qualityControl>
                <description>
                    <para>Georeferenced data were checked by plotting coordinates on a map.</para>
                </description>
            </qualityControl>
        </methods>


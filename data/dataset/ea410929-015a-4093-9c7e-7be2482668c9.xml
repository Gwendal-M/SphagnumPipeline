            <project id="NAW">
                <title>Natagriwal : mesures agroenvironnementales et climatiques, restauration Natura 2000</title>
                <personnel>
                    <individualName>
                    <givenName>Dopagne</givenName>
                    <surName>Claude</surName>
                    </individualName>
                    <role>ADMINISTRATIVE_POINT_OF_CONTACT</role>

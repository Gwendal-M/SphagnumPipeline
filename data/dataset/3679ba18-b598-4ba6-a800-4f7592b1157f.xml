            <project id="IMBIO">
                <title>Integration and Mobilization of Data about Biotic Diversity of Eukaryota in Resources of Polish Scientific Institutions (IMBIO)</title>
                <personnel>
                    <individualName>
                    <givenName>Piotr</givenName>
                    <surName>Tykarski</surName>
                    </individualName>
            <userId directory="https://orcid.org/">0000-0003-3259-8273</userId>
                    <role>ORIGINATOR</role>
